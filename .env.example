# YouTube Data API v3 key (https://console.cloud.google.com/ -> APIs & Services -> Credentials)
YOUTUBE_API_KEY=your-youtube-api-key-here

# Slack user token (xoxp-...) with chat:write scope so messages post as you.
# Create one at https://api.slack.com/apps -> "User Token Scopes" -> chat:write
SLACK_USER_TOKEN=xoxp-your-token-here

# Slack channel to post in (name with # or channel ID)
SLACK_CHANNEL=#fitness
